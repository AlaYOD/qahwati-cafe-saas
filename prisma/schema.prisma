// Qahwati Cafe SaaS — Prisma Schema
// Mirrors supabase/migrations/001_initial_schema.sql
// Used for: npx prisma db push (local dev) + npx prisma db seed

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// profiles
// ─────────────────────────────────────────────
model profiles {
  id         String    @id @db.Uuid
  full_name  String?
  role       String    @default("staff")
  avatar_url String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  orders     orders[]
  shifts     shifts[]
}

// ─────────────────────────────────────────────
// categories
// ─────────────────────────────────────────────
model categories {
  id         String    @id @default(uuid()) @db.Uuid
  name       String
  type       String    // 'menu' | 'inventory'
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  menu_items menu_items[]
}

// ─────────────────────────────────────────────
// menu_items
// ─────────────────────────────────────────────
model menu_items {
  id           String    @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  price        Decimal   @default(0) @db.Decimal(10, 3)
  image_url    String?
  is_available Boolean?  @default(true)
  category_id  String?   @db.Uuid
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  category    categories?   @relation(fields: [category_id], references: [id])
  order_items order_items[]
}

// ─────────────────────────────────────────────
// tables
// ─────────────────────────────────────────────
model tables {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @unique
  capacity         Int       @default(2)
  status           String    @default("available")
  zone             String    @default("indoor")
  current_order_id String?   @db.Uuid
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  orders orders[]
}

// ─────────────────────────────────────────────
// orders
// ─────────────────────────────────────────────
model orders {
  id             String    @id @default(uuid()) @db.Uuid
  table_id       String?   @db.Uuid
  user_id        String?   @db.Uuid
  status         String    @default("pending")
  payment_method String?
  total_amount   Decimal   @default(0) @db.Decimal(10, 3)
  customer_name  String?
  created_at     DateTime? @default(now()) @db.Timestamptz(6)

  table       tables?       @relation(fields: [table_id], references: [id])
  profile     profiles?     @relation(fields: [user_id], references: [id])
  order_items order_items[]
}

// ─────────────────────────────────────────────
// order_items
// ─────────────────────────────────────────────
model order_items {
  id           String    @id @default(uuid()) @db.Uuid
  order_id     String    @db.Uuid
  menu_item_id String?   @db.Uuid
  quantity     Int       @default(1)
  unit_price   Decimal   @db.Decimal(10, 3)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  order     orders      @relation(fields: [order_id], references: [id], onDelete: Cascade)
  menu_item menu_items? @relation(fields: [menu_item_id], references: [id])
}

// ─────────────────────────────────────────────
// inventory_items
// ─────────────────────────────────────────────
model inventory_items {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  category      String
  unit          String
  quantity      Decimal   @default(0) @db.Decimal(10, 3)
  min_level     Decimal   @default(0) @db.Decimal(10, 3)
  cost_per_unit Decimal   @default(0) @db.Decimal(10, 3)
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  updated_at    DateTime? @default(now()) @db.Timestamptz(6)
}

// ─────────────────────────────────────────────
// shifts
// ─────────────────────────────────────────────
model shifts {
  id               String    @id @default(uuid()) @db.Uuid
  user_id          String?   @db.Uuid
  opening_balance  Decimal   @default(0) @db.Decimal(10, 3)
  expected_balance Decimal   @default(0) @db.Decimal(10, 3)
  actual_balance   Decimal?  @db.Decimal(10, 3)
  status           String    @default("open")
  start_time       DateTime? @default(now()) @db.Timestamptz(6)
  end_time         DateTime? @db.Timestamptz(6)
  created_at       DateTime? @default(now()) @db.Timestamptz(6)

  profile      profiles?      @relation(fields: [user_id], references: [id])
  transactions transactions[]
}

// ─────────────────────────────────────────────
// transactions
// ─────────────────────────────────────────────
model transactions {
  id          String    @id @default(uuid()) @db.Uuid
  shift_id    String?   @db.Uuid
  amount      Decimal   @db.Decimal(10, 3)
  type        String    // 'sale_cash' | 'sale_card' | 'expense' | 'income' | 'opening'
  description String?
  created_at  DateTime? @default(now()) @db.Timestamptz(6)

  shift shifts? @relation(fields: [shift_id], references: [id], onDelete: Cascade)
}
